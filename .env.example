# ============================================================
# AUDUN Partners — QCM Platform — Environment Variables
# ============================================================
# Copier ce fichier en .env.local pour le dev local
# Dans Vercel : Settings → Environment Variables

# Supabase (trouvés dans Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (pour les opérations admin, JAMAIS côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (trouvé dans resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin
ADMIN_PASSWORD=changez-moi-avec-un-mot-de-passe-fort
ADMIN_EMAIL=recrutement@audun-partners.com

# Expéditeur vérifié dans Resend (doit correspondre à votre domaine vérifié)
FROM_EMAIL=noreply@audun-partners.com
